{
  "name": "daymark",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @daymark/calendar build && pnpm --filter @daymark/docs build && pnpm --filter @daymark/worker build",
    "test": "node test/calendar.test.mjs",
    "deploy": "pnpm --filter @daymark/worker exec wrangler deploy",
    "deploy:dry-run": "pnpm --filter @daymark/worker exec wrangler deploy --dry-run --outdir dist"
  },
  "devDependencies": {
    "@daymark/calendar": "workspace:*"
  }
}
